# Brewfile - packages managed by Homebrew on macOS and Linux
#
# if OS.mac? blocks: casks and macOS-specific tools (skipped on Linux)
# Everything else: cross-platform CLI tools installed on both platforms
#
# Usage:
#   macOS: brew bundle --file=~/dotfiles/packages/Brewfile
#   Linux: bash ~/dotfiles/install/linux-packages.sh

### Shells ###
brew "zsh"
brew "bash"
brew "fish"

### Editors ###
brew "vim"

### Git ###
brew "openssh"  # must precede system ssh in PATH; avoids OpenSSL version mismatch on Linux
brew "git"
brew "git-lfs"
brew "gh"
brew "glab"

### Search & Files ###
brew "tree"
# eza: modern ls (git column, tree mode). Brewfile, not cargo.txt — upstream
# publishes no darwin release binaries, so binstall would source-compile.
brew "eza"
brew "ncdu"
brew "fzf"
brew "jq"
brew "bc"  # statusline.sh arithmetic (ctx%/cost) — not guaranteed on minimal Linux
brew "bash-preexec"  # preexec/precmd hooks for bash — required by atuin history recording
brew "direnv"
brew "entr"
brew "xdelta"

### CLI Utilities ###
brew "wget"
brew "curl"
brew "less"
brew "rlwrap"
brew "cloc"
brew "imagemagick"
brew "fastfetch"
# opencl-headers: required by fastfetch for GPU info (CL/cl.h). Separate from
# opencl-icd-loader — headers and runtime are split packages.
brew "opencl-headers"
brew "fetch"
brew "tmux"
brew "moreutils"
brew "graphviz"

### Documents ###
brew "pandoc"

### Claude Code sandbox (Linux backend) ###
# macOS uses the built-in Seatbelt sandbox; Linux needs bubblewrap (user
# namespaces, no sudo) + socat (network proxy hop). See sandbox block in
# home/dot_claude/settings.json.
if OS.linux?
  brew "bubblewrap"
  brew "socat"
end

### Media ###
brew "ffmpeg"

### Monitoring ###
brew "htop"
brew "btop"
# glances: Python CLI tool — installed via uv (pip.txt) instead of brew.
# Brew's glances pulls python@3.13 which has the same PGO failures as 3.14
# on custom prefix, and we only patch 3.14.
# brew "glances"

### Compression ###
brew "lz4"
brew "zstd"

### Build Tools ###
brew "cmake"
brew "ninja"
brew "meson"
brew "gcc"
brew "gcc@13"
brew "gcc@15"
brew "llvm"   # clang, clang++, lldb, llvm-ar, opt, etc.
brew "llvm@21"
brew "llvm@22"
brew "lld"    # LLVM linker (now a separate formula)
brew "mold"   # fast modern linker
brew "ccache"  # C/C++ compiler cache
brew "sccache" # compiler cache with Rust support (RUSTC_WRAPPER)
# bacon: background cargo check/clippy/test on save (successor to cargo-watch).
# Brewfile, not cargo.txt — it publishes no prebuilt GitHub release binaries,
# and cargo.txt entries must binstall without source compilation.
brew "bacon"
brew "fftw"
brew "glfw"

### Languages ###
brew "python@3.14"  # patched on Linux (see patch-homebrew-python.sh); provides dev headers
brew "zig"
brew "go"  # Go toolchain; packages/go.txt drives `go install` via install/go.sh

### AI Coding Agents ###
brew "opencode"

### Token optimization ###
# rtk (Rust Token Killer): CLI proxy that compresses command output before it
# enters agent context (git/cargo/test runners etc.). Wired as a Claude Code
# PreToolUse hook in dot_claude/settings.json; other agents prefix manually.
# NOT cargo.txt: the crates.io `rtk` crate is an unrelated project.
brew "rtk"

### Memory stack (see install/memory.sh + docs/usage/agents.md) ###
# cass (session-history search) is installed by install/memory.sh directly
# from GitHub releases with checksum verification — its brew tap lags asset
# re-uploads (hit a stale-sha failure June 2026).
# sqlite: qmd's vector index needs Homebrew SQLite on macOS (system libsqlite3
# blocks loadable extensions)
brew "sqlite"

### Security ###
brew "gitleaks"  # secret scanning — also used as a global pre-push hook

### DevOps ###
brew "opentofu"
brew "mdbook"
brew "podman"
brew "podman-compose"

### Retro / Embedded ###
brew "cc65"

if OS.mac?
  ### Languages & Runtimes (macOS) ###
  brew "openjdk"
  # Free Wolfram Engine (full Mathematica kernel + wolframscript). Free for
  # personal/dev use; one-time activation with a Wolfram ID on first run:
  #   wolframscript   (prompts for login; 2 activation keys per account)
  # Used by the wolfram-language/wolfram-alpha agent skills via Bash — no MCP.
  # Linux: installer requires sudo, so headless boxes use the WolframAlpha
  # LLM API fallback documented in agents-common.md (~/.wolframalpha.env).
  cask "wolfram-engine"

  ### Dev Tools - VMs & Containers (macOS) ###
  brew "colima"
  brew "docker"
  brew "docker-compose"
  brew "docker-buildx"
  brew "qemu"
  brew "mas"

  ### Local AI ###
  brew "ollama"

  ### GPU Profiling ###
  cask "nvidia-nsight-systems"

  ### X11 ###
  brew "xorg-server"

  ### Terminal ###
  cask "ghostty"
  cask "tabby"

  ### Editors & IDEs ###
  cask "visual-studio-code"
  cask "cursor"

  ### AI Agent Tooling (macOS) ###
  # Linux gets these via go install — see packages/go.txt.
  tap "entireio/tap"
  cask "entire"  # captures AI agent sessions alongside git commits

  ### Window Management ###
  cask "nikitabobko/tap/aerospace"
  cask "linearmouse"
  cask "jordanbaird-ice"
  cask "enjoyable"

  ### Productivity ###
  cask "alfred"
  cask "the-unarchiver"

  ### Browsers ###
  cask "firefox"

  ### Media ###
  brew "mpv"
  cask "vlc"
  cask "elmedia-player"
  cask "gimp"
  cask "inkscape"
  cask "spotify"
  cask "obs"
  cask "blender"
  cask "kdenlive"
  cask "touchdesigner"

  ### Documents ###
  cask "libreoffice"

  ### Games ###
  cask "openemu"
  cask "retroarch"
  cask "nestopia"
  cask "slippi-dolphin"
  cask "steam"
  cask "prismlauncher"

  ### VMs ###
  cask "utm"

  ### Fonts ###
  cask "font-jetbrains-mono"
  cask "font-powerline-symbols"

  ### Utilities ###
  cask "balenaetcher"
end
