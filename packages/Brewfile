# Brewfile - packages managed by Homebrew on macOS and Linux
#
# if OS.mac? blocks: casks and macOS-specific tools (skipped on Linux)
# Everything else: cross-platform CLI tools installed on both platforms
#
# Usage:
#   macOS: brew bundle --file=~/dotfiles/packages/Brewfile
#   Linux: bash ~/dotfiles/install/linux-packages.sh

### Shells ###
brew "zsh"
brew "bash"
brew "fish"

### Editors ###
brew "vim"

### Git ###
brew "openssh"  # must precede system ssh in PATH; avoids OpenSSL version mismatch on Linux
brew "git"
brew "git-lfs"
brew "gh"
brew "glab"

### Search & Files ###
brew "tree"
# eza: modern ls (git column, tree mode). Brewfile, not cargo.txt — upstream
# publishes no darwin release binaries, so binstall would source-compile.
brew "eza"
brew "ncdu"
brew "fzf"
brew "jq"
brew "bc"  # statusline.sh arithmetic (ctx%/cost) — not guaranteed on minimal Linux
brew "bash-preexec"  # preexec/precmd hooks for bash — required by atuin history recording
brew "direnv"
brew "entr"
brew "xdelta"

### CLI Utilities ###
brew "wget"
brew "curl"
brew "less"
brew "rlwrap"
brew "cloc"
brew "imagemagick"
brew "fastfetch"
# opencl-headers: required by fastfetch for GPU info (CL/cl.h). Separate from
# opencl-icd-loader — headers and runtime are split packages.
brew "opencl-headers"
brew "fetch"
brew "tmux"
brew "moreutils"
brew "graphviz"

### Documents ###
brew "pandoc"

### Claude Code sandbox (Linux backend) ###
# macOS uses the built-in Seatbelt sandbox; Linux needs bubblewrap (user
# namespaces, no sudo) + socat (network proxy hop). See sandbox block in
# home/dot_claude/settings.json.
if OS.linux?
  brew "bubblewrap"
  brew "socat"
end

### Media ###
brew "ffmpeg"

### Monitoring ###
brew "htop"
brew "btop"
# glances: Python CLI tool — installed via uv (pip.txt) instead of brew.
# Brew's glances pulls python@3.13 which has the same PGO failures as 3.14
# on custom prefix, and we only patch 3.14.
# brew "glances"

