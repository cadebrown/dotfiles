# Brewfile - packages managed by Homebrew on macOS and Linux
#
# if OS.mac? blocks: casks and macOS-specific tools (skipped on Linux)
# Everything else: cross-platform CLI tools installed on both platforms
#
# Usage:
#   macOS: brew bundle --file=~/dotfiles/packages/Brewfile
#   Linux: bash ~/dotfiles/install/linux-packages.sh

### Shells ###
brew "zsh"
brew "bash"
brew "fish"

### Editors ###
brew "vim"

### Git ###
brew "openssh"  # must precede system ssh in PATH; avoids OpenSSL version mismatch on Linux
brew "git"
brew "git-lfs"
brew "gh"
brew "glab"

### Search & Files ###
brew "tree"
brew "ncdu"
brew "fzf"
brew "jq"
brew "direnv"
brew "entr"
brew "xdelta"

### CLI Utilities ###
brew "wget"
brew "curl"
brew "less"
brew "rlwrap"
brew "cloc"
brew "imagemagick"
brew "fastfetch"
# opencl-headers: required by fastfetch for GPU info (CL/cl.h). Separate from
# opencl-icd-loader — headers and runtime are split packages.
brew "opencl-headers"
brew "fetch"
brew "tmux"
brew "moreutils"
brew "graphviz"

### Documents ###
brew "pandoc"

### Media ###
brew "ffmpeg"

### Monitoring ###
brew "htop"
brew "btop"
# glances: Python CLI tool — installed via uv (pip.txt) instead of brew.
# Brew's glances pulls python@3.13 which has the same PGO failures as 3.14
# on custom prefix, and we only patch 3.14.
# brew "glances"

### Compression ###
brew "lz4"
brew "zstd"

### Build Tools ###
brew "cmake"
brew "ninja"
brew "meson"
brew "gcc"
brew "gcc@13"
brew "gcc@15"
brew "llvm"   # clang, clang++, lldb, llvm-ar, opt, etc.
brew "llvm@21"
brew "llvm@22"
brew "lld"    # LLVM linker (now a separate formula)
brew "mold"   # fast modern linker
brew "ccache"  # C/C++ compiler cache
brew "sccache" # compiler cache with Rust support (RUSTC_WRAPPER)
brew "fftw"
brew "glfw"

### Languages ###
brew "python@3.14"  # patched on Linux (see patch-homebrew-python.sh); provides dev headers
brew "zig"

### AI Coding Agents ###
brew "opencode"

### Security ###
brew "gitleaks"  # secret scanning — also used as a global pre-push hook

### DevOps ###
brew "opentofu"
brew "mdbook"
brew "podman"
brew "podman-compose"

### Retro / Embedded ###
brew "cc65"

