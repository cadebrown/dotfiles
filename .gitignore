# Directories
# .claude is machine-local (settings.local.json, .cc-writes) EXCEPT rules/,
# which is checked in — path-scoped instruction files loaded by Claude Code.
.claude/*
!.claude/rules/
dotfiles-*/
docs/book/
old/
/doc/          # stray rustdoc JSON (rust-docs MCP / `rustdoc` defaults output here); real docs live in docs/

# Secrets and credentials (should never be committed)
.env
.env.local
.env.*.local
*.pem
*.key
*.crt
*.p12
*.pfx
terraform.tfvars
!terraform.tfvars.example

# IDE / OS
.vscode/settings.json
.DS_Store
*.swp
