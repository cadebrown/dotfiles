{{ if eq .chezmoi.os "darwin" -}}
Include {{ .chezmoi.homeDir }}/.colima/ssh_config

{{ end -}}
Host *
    # Multiplexing — socket on local disk (not NFS)
    ControlPath /tmp/ssh-%C
    ControlMaster auto
    ControlPersist 600

    # Key management
    IgnoreUnknown UseKeychain
    AddKeysToAgent yes
{{ if eq .chezmoi.os "darwin" -}}
    UseKeychain yes
{{ end -}}

    # Reliability
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ConnectTimeout 10

    # Security
    StrictHostKeyChecking accept-new
    HashKnownHosts yes
    IdentitiesOnly yes

    # Agent forwarding is opt-in per host (see example below)
    ForwardAgent no

# Example: enable agent forwarding for jump hosts
# Host jump.example.com
#     ForwardAgent yes
