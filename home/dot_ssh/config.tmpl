{{ if eq .chezmoi.os "darwin" -}}
# Colima injects SSH config for managed VMs (socket forwarding, etc.)
# Using a glob so OpenSSH silently skips this if Colima hasn't run yet —
# a literal path to a non-existent file causes "Bad configuration option: include".
Include {{ .chezmoi.homeDir }}/.colima/*ssh_config

{{ end -}}
# Machine-specific and private host blocks (e.g. from dotfiles-nvidia)
Include ~/.ssh/config.d/*

Host *
    # Multiplexing — socket on local disk (not NFS)
    ControlPath /tmp/ssh-%C
    ControlMaster auto
    ControlPersist 600

    # Key management
    IgnoreUnknown UseKeychain
    AddKeysToAgent yes
{{ if eq .chezmoi.os "darwin" -}}
    UseKeychain yes
{{ end -}}

    # Reliability
    ServerAliveInterval 60
    ServerAliveCountMax 3
    ConnectTimeout 10

    # Security
    StrictHostKeyChecking accept-new
    HashKnownHosts yes

    # Agent forwarding — on by default; disable per-host if needed
    ForwardAgent yes
