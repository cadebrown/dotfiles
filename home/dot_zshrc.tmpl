# .zshrc - interactive ZSH shell configuration

### ZSH OPTIONS ###

# Completion
setopt MENU_COMPLETE        # tab cycles through completion menu (no ambiguous list)

# History: deduplication, formatting, cross-session sharing
setopt EXTENDED_HISTORY     # record timestamp + duration in history file
setopt HIST_IGNORE_DUPS     # don't record consecutive duplicate commands
setopt HIST_LEX_WORDS       # use shell quoting when writing history entries
setopt HIST_REDUCE_BLANKS   # strip redundant whitespace from history entries
setopt SHARE_HISTORY        # share history across all open sessions in real time
setopt APPEND_HISTORY       # append rather than overwrite history file on exit
setopt HIST_EXPIRE_DUPS_FIRST  # evict duplicates first when history file is full
setopt HIST_IGNORE_SPACE    # don't record commands prefixed with a space (private cmds)
setopt HIST_FCNTL_LOCK      # use fcntl locks for history file (more NFS-compatible)

# Globbing
setopt EXTENDED_GLOB        # enable #, ~, ^ glob operators
setopt NUMERIC_GLOB_SORT    # sort file names with embedded numbers numerically
setopt GLOB_STAR_SHORT      # ** expands without requiring trailing / (like bash globstar)

# Arithmetic
setopt C_BASES              # print hex/octal literals in C notation (0x1F, 017)
setopt C_PRECEDENCES        # arithmetic uses C operator precedence rules

# Misc
setopt RM_STAR_SILENT       # skip "are you sure?" for rm * (deliberate: trust yourself)
setopt CHASE_LINKS          # resolve symlinks in cd/pwd so $PWD shows the real path

### HISTORY ###

# Use the conventional ~/.zsh_history. Lives at $HOME (precious by default,
# survives any ~/.local/{cache,bin,plat_*} cleanup), and matches what every
# zsh tutorial assumes — tools that grep history find it where they expect.
HISTFILE="$HOME/.zsh_history"
HISTSIZE=500000
SAVEHIST=500000

### OH-MY-ZSH ###

export ZSH="$HOME/.oh-my-zsh"
export ZSH_CUSTOM="$HOME/.oh-my-zsh-custom"
export ZSH_THEME=""  # empty = use custom prompt (pure)

# Redirect zcompdump out of $HOME — it's a cache file, ~/.cache is fine
# Must be set before oh-my-zsh loads (it calls compinit internally)
: "${XDG_CACHE_HOME:=$HOME/.cache}"
[[ -d $XDG_CACHE_HOME/zsh ]] || mkdir -p "$XDG_CACHE_HOME/zsh" 2>/dev/null
ZSH_COMPDUMP="$XDG_CACHE_HOME/zsh/zcompdump-${HOST}-${ZSH_VERSION}"

# zsh-completions: extend fpath before compinit runs (oh-my-zsh calls compinit)
fpath+=("$ZSH_CUSTOM/plugins/zsh-completions/src")

# nvm: lazy-load so sourcing the ~4000 line nvm.sh doesn't hit startup time.
# Creates stub functions for nvm/node/npm/npx that source nvm on first use.
zstyle ':omz:plugins:nvm' lazy yes

# z: jump to frecent directories (tracks usage, `z foo` → cd to best match)
# git: git aliases and prompt helpers (used by pure theme)
# nvm: lazy-load stub (configured above via zstyle)
# direnv: hook into chpwd to load/unload .envrc per directory
# colorize: syntax-highlight file output via `ccat` / `cless`
# zsh-autosuggestions: ghost-text history suggestions as you type
# fast-syntax-highlighting: real-time command-line syntax highlighting
plugins=(z git nvm direnv colorize zsh-autosuggestions fast-syntax-highlighting)

if [ -f "$ZSH/oh-my-zsh.sh" ]; then
    source "$ZSH/oh-my-zsh.sh"
fi

### PROMPT (pure) ###

if [ -d "$ZSH_CUSTOM/themes/pure" ]; then
    fpath+=("$ZSH_CUSTOM/themes/pure")
    autoload -Uz promptinit && promptinit
    zstyle :prompt:pure:git:stash show yes
    prompt pure
    # Fix %n on hosts where getpwuid() fails (broken NSS/LDAP — no passwd
    # entry for our uid). %n reads zsh's special $USERNAME param, which we
    # can't assign without triggering setuid(). Replace %n in the prompt
    # with $USER (always set by SSH/login, no NSS lookup).
    [[ -z "$USERNAME" && -n "$USER" ]] && PROMPT=${PROMPT//\%n/$USER}
fi

### ALIASES ###

alias g='git'
function gsm { if [[ $# -eq 0 ]]; then git submodule update --init --recursive; else git submodule "$@"; fi }

# gwtize — convert a standard git repo to bare+worktree layout in-place.
# Usage:
#   gwtize              — convert, worktree name = current branch (/ → -)
#   gwtize work         — convert, worktree name = "work"
#   gwtize work feat    — also create worktree for 'feat' branch
gwtize() {
    # 1. Validate — must be at repo root, not bare, not already a worktree
    if [[ ! -d .git ]]; then
        if [[ -f .git ]]; then
            print "gwtize: already inside a worktree (.git is a file)" >&2
            return 1
        fi
        print "gwtize: not at a git repo root (no .git/ directory)" >&2
        return 1
    fi
    if git rev-parse --is-bare-repository 2>/dev/null | grep -q true; then
        print "gwtize: repo is already bare" >&2
        return 1
    fi

    # 2. Capture current state
    local branch detached=0 commit
    branch=$(git symbolic-ref --short HEAD 2>/dev/null) || {
        detached=1
        commit=$(git rev-parse --short HEAD)
    }

    # Determine worktree directory name
    local wt_name="${1:-}"
    if [[ -z "$wt_name" ]]; then
        if (( detached )); then
            wt_name="detached-${commit}"
        else
            wt_name="${branch//\//-}"
        fi
    fi
    shift 2>/dev/null || true
    local -a extra_branches=("$@")

    # Save the index to preserve staged state
    local saved_index
    saved_index=$(mktemp)
    cp .git/index "$saved_index"

    # 3. Convert .git → .bare
    mv .git .bare
    git --git-dir=.bare config core.bare true
    git --git-dir=.bare config --unset core.worktree 2>/dev/null || true

    # 4. Create worktree linkage (no checkout — we'll move files ourselves)
    if (( detached )); then
        git --git-dir=.bare worktree add --no-checkout --detach "$wt_name" "$commit"
    else
        git --git-dir=.bare worktree add --no-checkout "$wt_name" "$branch"
    fi

    # 5. Move all files/dirs (except .bare/ and wt_name/) into the worktree
    setopt local_options GLOB_DOTS
    local item
    for item in *(N); do
        [[ "$item" == .bare || "$item" == "$wt_name" ]] && continue
        mv -- "$item" "$wt_name/"
    done

    # 6. Restore index — preserves staged vs unstaged state exactly
    cp "$saved_index" ".bare/worktrees/${wt_name}/index"
    rm -f "$saved_index"

    # 7. Extra branches
    local eb
    for eb in "${extra_branches[@]}"; do
        [[ -z "$eb" ]] && continue
        git --git-dir=.bare worktree add "$eb" "$eb" 2>&1 || {
            print "gwtize: warning: failed to add worktree for '$eb'" >&2
        }
    done

    # 8. Summary
    print "gwtize: converted to bare+worktree layout"
    git --git-dir=.bare worktree list

    # 9. cd into the primary worktree
    cd "$wt_name" || return 1
}

alias p='python'
alias e='vim'
alias cat='bat --paging=never'

alias datestamp='date +"%Y%m%d"'
alias timestamp='date +"%Y%m%d%H%M%S"'
alias verify-path='bash ~/dotfiles/install/verify-path.sh'
alias cursor-sync='bash ~/dotfiles/install/cursor.sh sync-extensions'

# Codex profile shortcuts. The default built-in permission profile removes the
# filesystem/network sandbox and approval prompts.
#   codex   = Sol, high reasoning, unrestricted host access
#   codexs  = Sol, extra-high reasoning, medium verbosity
#   codexr  = Sol, extra-high reasoning, read-only permissions
alias codexs='codex -p deep'
alias codexr='codex -p review'

# codex launcher — resolve MCP credentials at launch so config.toml can
# reference them via *_env_var, keeping tokens off disk. Lazy (resolved per
# codex launch, not per shell startup); caller-provided values win.
#   GH_TOKEN          → GitHub MCP (bearer_token_env_var)
#   GOOGLE_MCP_TOKEN  → Google official MCP servers (ADC access token, ~1h)
#   GOOGLE_CLOUD_PROJECT → x-goog-user-project quota project for the above
codex() {
    GH_TOKEN="${GH_TOKEN:-$(command gh auth token 2>/dev/null)}" \
    GOOGLE_MCP_TOKEN="${GOOGLE_MCP_TOKEN:-$(command gcloud auth application-default print-access-token 2>/dev/null)}" \
    GOOGLE_CLOUD_PROJECT="${GOOGLE_CLOUD_PROJECT:-$(command gcloud config get-value project 2>/dev/null)}" \
        command codex "$@"
}

# OpenCode consumes the same short-lived MCP credentials as Codex and starts
# in auto-approve mode. Explicit deny rules (the review agent) still apply.
opencode() {
    GH_TOKEN="${GH_TOKEN:-$(command gh auth token 2>/dev/null)}" \
    GOOGLE_MCP_TOKEN="${GOOGLE_MCP_TOKEN:-$(command gcloud auth application-default print-access-token 2>/dev/null)}" \
    GOOGLE_CLOUD_PROJECT="${GOOGLE_CLOUD_PROJECT:-$(command gcloud config get-value project 2>/dev/null)}" \
        command opencode --auto "$@"
}

# mlxserve — start the MLX OpenAI-compat server on localhost:8080.
# Uses mlx-openai-server (NOT mlx_lm.server) for tool/function calling.
#
# Default model: Qwen3.6-27B-MLX-8bit (Apr 2026, dense VLM, reasoning-tuned).
# All requests use served-model-name "qwen3.6-27b" regardless of which
# physical model is loaded — keeps opencode/pi configs stable when
# you swap models.
#
# KV cache quantization (--kv-bits 8) is enabled ONLY for lm-mode models;
# the VLM batch scheduler in mlx-openai-server doesn't accept kv_bits yet
# (TypeError on BatchGenerator). Multimodal models run with full-precision KV.
#
#   mlxserve                  # default (qwen3.6-27b)
#   mlxserve coder-next       # mlx-community/Qwen3-Coder-Next-8bit (80B/3B MoE)
#   mlxserve qwen3.6-35b-a3b  # mlx-community/Qwen3.6-35B-A3B-8bit (35B/3B MoE)
#   mlxserve <full-hf-id>     # arbitrary model
mlxserve() {
    # Notes:
    # - --model-type lm everywhere: mlx-openai-server v1.8.1's VLM batch
    #   scheduler is broken (always passes kv_bits to BatchGenerator which
    #   rejects the kwarg, fails on first request). lm path works for text-only
    #   use of VLM weights — all we need for coding.
    # - Qwen3.6 emits Coder-style XML tool calls (verified via raw probe), so
    #   tool parser is qwen3_coder even on non-Coder variants.
    # - Reasoning parser is qwen3_5 (model arch is "Qwen3.5 ForConditionalGeneration").
    local arg="${1:-qwen3.6-27b}" model parser=qwen3_coder rparser=qwen3_5
    case "$arg" in
        qwen3.6-27b)
            model="unsloth/Qwen3.6-27B-MLX-8bit" ;;
        qwen3.6-35b-a3b)
            model="mlx-community/Qwen3.6-35B-A3B-8bit"
            rparser=qwen3_moe ;;
        coder-next|qwen3-coder-next)
            model="mlx-community/Qwen3-Coder-Next-8bit"
            rparser="" ;;
        *)  model="$arg" ;;
    esac
    local mtype=lm
    local port="${MLX_PORT:-8080}"
    echo "▸ MLX server starting on http://localhost:$port"
    echo "  model: $model  (served as 'qwen3.6-27b')"
    echo "  type: $mtype  parser: $parser  reasoning: ${rparser:-none}"
    local args=(launch
        --model-type "$mtype"
        --model-path "$model"
        --served-model-name qwen3.6-27b
        --tool-call-parser "$parser"
        --enable-auto-tool-choice
        --host 127.0.0.1 --port "$port")
    [[ -n "$rparser" ]] && args+=(--reasoning-parser "$rparser")
    args+=(--kv-bits 8 --kv-group-size 64)   # 8-bit KV cache (q8_0 attn)
    mlx-openai-server "${args[@]}"
}

# mlxstart / mlxstop / mlxstatus — control the LaunchAgent (dev.cade.mlxserve).
# Battery: an idle MLX server holds the model in unified memory but burns very
# little CPU/GPU power. Stop it when on battery + not coding for hours.
alias mlxstart='launchctl bootstrap "gui/$(id -u)" "$HOME/Library/LaunchAgents/dev.cade.mlxserve.plist"'
alias mlxstop='launchctl bootout "gui/$(id -u)/dev.cade.mlxserve"'
alias mlxstatus='launchctl print "gui/$(id -u)/dev.cade.mlxserve" 2>/dev/null | head -20 || echo "mlxserve LaunchAgent not loaded"'

# mlxpull — pre-download a model without starting a server. Same alias map as mlxserve.
# `mlxserve <name>` already auto-downloads on first request; use this when you want
# to fill the cache ahead of time (e.g. before a flight).
mlxpull() {
    local arg="${1:?usage: mlxpull <alias|hf-id>}" model
    case "$arg" in
        qwen3.6-27b)            model="unsloth/Qwen3.6-27B-MLX-8bit" ;;
        qwen3.6-35b-a3b)        model="mlx-community/Qwen3.6-35B-A3B-8bit" ;;
        coder-next|qwen3-coder-next) model="mlx-community/Qwen3-Coder-Next-8bit" ;;
        *)                       model="$arg" ;;
    esac
    echo "▸ pulling $model into HF cache ($HF_HOME)"
    python3 -c "from huggingface_hub import snapshot_download; snapshot_download('$model')"
}

