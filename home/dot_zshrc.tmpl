# .zshrc - interactive ZSH shell configuration

### ZSH OPTIONS ###

setopt MENU_COMPLETE
setopt EXTENDED_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_LEX_WORDS
setopt HIST_REDUCE_BLANKS
setopt SHARE_HISTORY
setopt APPEND_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_SPACE
setopt EXTENDED_GLOB
setopt NUMERIC_GLOB_SORT
setopt GLOB_STAR_SHORT
setopt C_BASES
setopt C_PRECEDENCES
setopt RM_STAR_SILENT
setopt CHASE_LINKS

### OH-MY-ZSH ###

export ZSH="$HOME/.oh-my-zsh"
export ZSH_CUSTOM="$HOME/.oh-my-zsh-custom"
export ZSH_THEME=""  # empty = use custom prompt (pure)

# zsh-completions: extend fpath before compinit runs
fpath+=("$ZSH_CUSTOM/plugins/zsh-completions/src")

autoload -Uz compinit && compinit
autoload -Uz bashcompinit && bashcompinit

plugins=(z git direnv colorize zsh-autosuggestions fast-syntax-highlighting)

if [ -f "$ZSH/oh-my-zsh.sh" ]; then
    source "$ZSH/oh-my-zsh.sh"
fi

### PROMPT (pure) ###

if [ -d "$ZSH_CUSTOM/themes/pure" ]; then
    fpath+=("$ZSH_CUSTOM/themes/pure")
    autoload -Uz promptinit && promptinit
    zstyle :prompt:pure:git:stash show yes
    prompt pure
fi

### ALIASES ###

alias g='git'
alias p='uv run python'
alias e='vim'
alias cat='bat --paging=never'

alias datestamp='date +"%Y%m%d"'
alias timestamp='date +"%Y%m%d%H%M%S"'

{{ if eq .chezmoi.os "linux" -}}
alias open='xdg-open'
{{ end -}}

### COMPLETIONS ###

# Xan CSV tool
if command -v xan &>/dev/null; then
    function __xan { xan compgen "$1" "$2" "$3"; }
    complete -F __xan -o default xan
fi

# Zoxide
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init zsh)"
fi

# fzf
if command -v fzf &>/dev/null; then
    eval "$(fzf --zsh)"
fi
