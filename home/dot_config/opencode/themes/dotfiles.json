{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "steel":   "#5fafd7",
    "sky":     "#5fffff",
    "purple":  "#af5fff",
    "pink":    "#d787af",
    "green":   "#87d787",
    "grey":    "#9e9e9e",
    "red":     "#ff5f5f",
    "orange":  "#ff8700",
    "gold":    "#ffd700",
    "blue":    "#00afd7",
    "fg":      "#e4e4e4",
    "panelBg": "#1c1c1c",
    "elemBg":  "#262626"
  },
  "theme": {
    "primary":           "steel",
    "secondary":         "sky",
    "accent":            "purple",
    "info":              "sky",
    "warning":           "gold",
    "error":             "red",
