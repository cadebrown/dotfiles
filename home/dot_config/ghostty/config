# Ghostty terminal configuration

font-family = JetBrains Mono
font-size = 13

# Use system theme
theme = dark:Gruvbox Dark,light:Gruvbox Light

# Window
window-padding-x = 8
window-padding-y = 8
window-decoration = true

# Shell integration
shell-integration = zsh
# `path` exposes the app-bundled CLI. The SSH features propagate Ghostty's
# environment and install its terminfo on hosts that do not know xterm-ghostty.
shell-integration-features = cursor,sudo,title,path,ssh-env,ssh-terminfo

# Scrollback
scrollback-limit = 100000

# Cursor
cursor-style = bar
cursor-style-blink = false

# Bell (disable everything)
bell-features = no-system,no-audio,no-attention,no-title,no-border

# Local selection and OSC 52 writes both land in the macOS clipboard. Remote
# programs may write it; reads still require confirmation.
copy-on-select = clipboard
clipboard-write = allow
clipboard-read = ask

# Quick terminal (drop-down hotkey window)
# Global hotkey: Option+` summons a slide-down terminal from the top
keybind = global:alt+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0
quick-terminal-space-behavior = move
background-opacity = 0.9

# macOS-specific
macos-option-as-alt = true
