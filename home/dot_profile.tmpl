# ~/.profile — sourced by both .zprofile and .bash_profile
# PLAT-independent program defaults. All vars here use only $HOME or literal values.
# Guard prevents double-sourcing on bash→zsh exec (zsh inherits bash's env).
[ -n "$_PROFILE_SOURCED" ] && return 0
export _PROFILE_SOURCED=1

### GENERAL ###

export EDITOR=vim

# Pager and viewer defaults
export LESS="-RF"                   # -R: ANSI colors; -F: quit if fits on one screen
export PAGER="less"
if command -v bat >/dev/null 2>&1; then
    export MANPAGER="sh -c 'col -bx | bat -l man -p'"  # col -bx strips man's overstrike formatting
    export BAT_THEME="Monokai Extended"
    export BAT_STYLE="numbers,changes,header-filename"
fi

# ripgrep config
export RIPGREP_CONFIG_PATH="${HOME}/.config/ripgrep/ripgreprc"

### CMAKE ###

export CMAKE_EXPORT_COMPILE_COMMANDS=1  # write compile_commands.json for clangd/LSP
export CMAKE_COLOR_DIAGNOSTICS=ON       # colored compiler output even when piped
export CMAKE_GENERATOR=Ninja            # default to Ninja for faster incremental builds
export CMAKE_BUILD_PARALLEL_LEVEL="$(nproc 2>/dev/null || sysctl -n hw.logicalcpu 2>/dev/null || echo 4)"
export CLICOLOR_FORCE=1                 # force color in ls/grep/etc when piped
export USE_CCACHE=ON                    # enable ccache in CMake projects that check this var

### TOOLCHAIN ###

# Toolchain selection — versioned cmake files live in $_LOCAL_PLAT/cmake/toolchains/.
# Linux default: GCC (works with CUDA host compiler, no clang/CUDA friction).
# macOS default: LLVM (Xcode clang is ancient; brew LLVM is the primary toolchain).
# CC/CXX/AR/etc are only set for GCC — LLVM relies solely on the CMake toolchain file
# since the CMake file is the single owner for CMake builds, and non-CMake builds
# on LLVM should set the compiler explicitly per-project.
if [ -n "${HOMEBREW_PREFIX:-}" ]; then
    _os="$(uname -s)"
    if [ "$_os" = "Linux" ]; then
        if [ -x "$HOMEBREW_PREFIX/bin/gcc-13" ]; then
            export CC="${CC:-$HOMEBREW_PREFIX/bin/gcc-13}"
            export CXX="${CXX:-$HOMEBREW_PREFIX/bin/g++-13}"
            export AR="${AR:-$HOMEBREW_PREFIX/bin/gcc-ar-13}"
            export RANLIB="${RANLIB:-$HOMEBREW_PREFIX/bin/gcc-ranlib-13}"
            export NM="${NM:-$HOMEBREW_PREFIX/bin/gcc-nm-13}"
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/gcc-13.cmake}"
        elif [ -x "$HOMEBREW_PREFIX/opt/llvm/bin/clang" ]; then
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/llvm-22.cmake}"
        fi
        # RPATH over RUNPATH: mold and lld default to DT_RUNPATH, which the
        # dynamic linker checks after ld.so.cache — the system's older
        # libstdc++ wins.  Force DT_RPATH for non-CMake builds (make, meson,
        # autotools).  CMake builds get this from the toolchain files instead.
        export LDFLAGS="${LDFLAGS:+$LDFLAGS }-Wl,--disable-new-dtags"
    else
        if [ -x "$HOMEBREW_PREFIX/opt/llvm/bin/clang" ]; then
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/llvm-22.cmake}"
        elif [ -x "$HOMEBREW_PREFIX/bin/gcc-13" ]; then
            export CC="${CC:-$HOMEBREW_PREFIX/bin/gcc-13}"
            export CXX="${CXX:-$HOMEBREW_PREFIX/bin/g++-13}"
            export AR="${AR:-$HOMEBREW_PREFIX/bin/gcc-ar-13}"
            export RANLIB="${RANLIB:-$HOMEBREW_PREFIX/bin/gcc-ranlib-13}"
            export NM="${NM:-$HOMEBREW_PREFIX/bin/gcc-nm-13}"
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/gcc-13.cmake}"
        fi
    fi
    unset _os
fi

### CUDA ###

# $_LOCAL_PLAT/.cuda is the per-PLAT symlink to the CUDA toolkit root.
# CUDA is not managed by bootstrap — create the symlink manually:
#   ln -sfn /usr/local/cuda "$_LOCAL_PLAT/.cuda"          # system toolkit
#   ln -sfn /opt/nvidia/cuda/12.6 "$_LOCAL_PLAT/.cuda"    # versioned install
# Different machines on a shared NFS home can point to different CUDA versions.
# CMake picks this up via CMAKE_CUDA_COMPILER in the active toolchain file.
if [ -e "$_LOCAL_PLAT/.cuda" ]; then
    _cuda_root="$(realpath "$_LOCAL_PLAT/.cuda" 2>/dev/null || true)"
    if [ -d "$_cuda_root" ]; then
        export CUDA_PATH="$_cuda_root"
        export CUDAToolkit_ROOT="$_cuda_root"
        case ":${PATH:-}:" in
            *":$_cuda_root/bin:"*) ;;
            *) export PATH="$_cuda_root/bin${PATH:+:$PATH}" ;;
        esac
    fi
    unset _cuda_root
fi

### COMPILER CACHING ###
# Full ccache config reference: https://ccache.dev/manual/latest.html#_configuration_settings
# Key principle: ccache hashes (compiler, flags, preprocessed source) → object.
# Every setting below is about maximising hit rate without sacrificing correctness.

if command -v ccache >/dev/null 2>&1; then
    # Tell CMake to prefix every compile command with ccache.
    # https://cmake.org/cmake/help/latest/variable/CMAKE_LANG_COMPILER_LAUNCHER.html
    export CMAKE_C_COMPILER_LAUNCHER=ccache
    export CMAKE_CXX_COMPILER_LAUNCHER=ccache
    export CMAKE_CUDA_COMPILER_LAUNCHER=ccache

    # Cache directory. scratch.sh symlinks ~/.cache → local scratch partition,
    # so this never counts against the NFS home quota.
    export CCACHE_DIR="${HOME}/.cache/ccache"

    # CCACHE_BASEDIR — the single most important setting for hit rate.
    # https://ccache.dev/manual/latest.html#config_base_dir
    #
    # ccache hashes the *preprocessed* source, which embeds absolute #line
    # directives. Two builds of the same file in different directories
    # (e.g. build/ vs build-release/, or two checkouts of the same repo)
    # always miss without this, because those absolute paths differ.
    #
    # With BASEDIR set, ccache rewrites any path that starts with this prefix
    # to a relative path before hashing — so build directory is irrelevant.
    #
    # We resolve the real path of ~/scratch (pwd -P follows the symlink) rather
    # than using $HOME, because source trees live under the scratch root
    # (e.g. /home/scratch.cadeb_ent_1/dev/...), which is a *different* filesystem
    # root than $HOME (/home/cadeb/). Setting BASEDIR=$HOME would never match
    # paths under scratch and the feature would do nothing.
    #
    # Trade-off: DWARF debug info will embed paths relative to BASEDIR instead
    # of absolute paths. gdb/lldb source lookup still works when running from
    # the same root; or add "set substitute-path <old> <new>" to .gdbinit.
    if [ -e "${HOME}/scratch" ]; then
        export CCACHE_BASEDIR="$(cd "${HOME}/scratch" && pwd -P)"
    else
        export CCACHE_BASEDIR="${HOME}"
    fi

    # Hash the compiler binary by *content*, not mtime (the default).
    # https://ccache.dev/manual/latest.html#config_compiler_check
    # Mtime is fragile: brew reinstall, module swap, or a recompiled toolchain
    # can produce a binary with the same timestamp → wrong cache hits. Content
    # is slower to check once but guarantees correctness across compiler updates.
    export CCACHE_COMPILERCHECK=content

    # CCACHE_SLOPPINESS — a comma-separated list of things ccache is allowed
    # to ignore when computing the hash. Each relaxation trades a theoretical
    # correctness edge case for a higher hit rate.
    # https://ccache.dev/manual/latest.html#config_sloppiness
    #
    # file_stat_matches:
    #   Use mtime+size to decide whether an included file has changed, instead
    #   of rehashing its content on every lookup. Safe as long as editors update
    #   mtime when they write (all normal editors do). Big speedup for headers.
    #
    # time_macros:
    #   Cache TUs that use __DATE__ / __TIME__. Without this, ccache refuses to
    #   cache any file that expands these macros because the output changes every
    #   second. With it, the cached object has the original compile timestamp
    #   baked in. Acceptable for dev builds — release/dist builds should be
    #   clean anyway, and build-date strings in dev binaries are rarely load-bearing.
    export CCACHE_SLOPPINESS=file_stat_matches,time_macros

    # Write cached objects back to the build directory via hardlinks instead of
    # copies. https://ccache.dev/manual/latest.html#config_hard_link
    # Since the cache dir and build dirs both live on the same scratch partition,
    # hardlinking is free (no data movement, just a new directory entry). This
    # halves the I/O for cache hits and saves scratch space for large CUDA TUs.
    # Note: object files must not be modified in-place after linking (they won't be).
    export CCACHE_HARDLINK=1

    # Size the cache at 2% of the scratch partition, clamped to [10G, 100G].
    # df -Pk gives POSIX-portable output in 1K blocks; column 2 is total size.
    # https://ccache.dev/manual/latest.html#config_max_size
    _cache_total_kb="$(df -Pk "${HOME}/.cache" 2>/dev/null | awk 'NR==2{print $2}')"
    if [ -n "$_cache_total_kb" ]; then
        _cache_target_g=$(( _cache_total_kb / 50 / 1024 / 1024 ))
        [ "$_cache_target_g" -lt 10  ] && _cache_target_g=10
        [ "$_cache_target_g" -gt 100 ] && _cache_target_g=100
        export CCACHE_MAXSIZE="${_cache_target_g}G"
        unset _cache_total_kb _cache_target_g
    else
        export CCACHE_MAXSIZE=10G
    fi
fi
if command -v sccache >/dev/null 2>&1; then
    export RUSTC_WRAPPER=sccache
    export SCCACHE_DIR="${HOME}/.cache/sccache"  # lands on scratch when ~/.cache is symlinked
    # Size cache at 2% of total partition size, clamped to [10G, 100G].
    _cache_total_kb="$(df -Pk "${HOME}/.cache" 2>/dev/null | awk 'NR==2{print $2}')"
    if [ -n "$_cache_total_kb" ]; then
        _cache_target_g=$(( _cache_total_kb / 50 / 1024 / 1024 ))
        [ "$_cache_target_g" -lt 10  ] && _cache_target_g=10
        [ "$_cache_target_g" -gt 100 ] && _cache_target_g=100
        export SCCACHE_CACHE_SIZE="${_cache_target_g}G"
        unset _cache_total_kb _cache_target_g
    else
        export SCCACHE_CACHE_SIZE=10G
    fi
fi

### HOMEBREW ###

export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_NO_INSTALL_FROM_API=1

### RUST ###

export RUST_BACKTRACE=1                      # show backtraces on panic (dev default)
export CARGO_NET_GIT_FETCH_WITH_CLI=true     # use git CLI for SSH key auth — critical on NFS homes

### PYTHON ###

export PYTHONDONTWRITEBYTECODE=1    # no .pyc files — saves NFS quota, avoids stale cache conflicts
export PYTHONFAULTHANDLER=1         # enable crash dumps — useful for debugging C extensions
if [ -e "$HOME/.pythonrc" ]; then
    export PYTHONSTARTUP="$HOME/.pythonrc"
fi
