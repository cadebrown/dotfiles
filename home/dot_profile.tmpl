# ~/.profile — sourced by both .zprofile and .bash_profile
# PLAT-independent program defaults. All vars here use only $HOME or literal values.
# Guard prevents double-sourcing on bash→zsh exec (zsh inherits bash's env).
[ -n "$_PROFILE_SOURCED" ] && return 0
export _PROFILE_SOURCED=1

### GENERAL ###

export EDITOR=vim

# Pager and viewer defaults
export LESS="-RF"                   # -R: ANSI colors; -F: quit if fits on one screen
export PAGER="less"
if command -v bat >/dev/null 2>&1; then
    export MANPAGER="sh -c 'col -bx | bat -l man -p'"  # col -bx strips man's overstrike formatting
    export BAT_THEME="Monokai Extended"
    export BAT_STYLE="numbers,changes,header-filename"
fi

# ripgrep config
export RIPGREP_CONFIG_PATH="${HOME}/.config/ripgrep/ripgreprc"

### CMAKE ###

export CMAKE_EXPORT_COMPILE_COMMANDS=1  # write compile_commands.json for clangd/LSP
export CMAKE_COLOR_DIAGNOSTICS=ON       # colored compiler output even when piped
export CMAKE_GENERATOR=Ninja            # default to Ninja for faster incremental builds
export CMAKE_BUILD_PARALLEL_LEVEL="$(nproc 2>/dev/null || sysctl -n hw.logicalcpu 2>/dev/null || echo 4)"
export CLICOLOR_FORCE=1                 # force color in ls/grep/etc when piped
export USE_CCACHE=ON                    # enable ccache in CMake projects that check this var

### TOOLCHAIN ###

# Toolchain selection — versioned cmake files live in $_LOCAL_PLAT/cmake/toolchains/.
# Linux default: GCC (works with CUDA host compiler, no clang/CUDA friction).
# macOS default: LLVM (Xcode clang is ancient; brew LLVM is the primary toolchain).
# CC/CXX/AR/etc are only set for GCC — LLVM relies solely on the CMake toolchain file
# since the CMake file is the single owner for CMake builds, and non-CMake builds
# on LLVM should set the compiler explicitly per-project.
if [ -n "${HOMEBREW_PREFIX:-}" ]; then
    _os="$(uname -s)"
    if [ "$_os" = "Linux" ]; then
        if [ -x "$HOMEBREW_PREFIX/bin/gcc-15" ]; then
            export CC="${CC:-$HOMEBREW_PREFIX/bin/gcc-15}"
            export CXX="${CXX:-$HOMEBREW_PREFIX/bin/g++-15}"
            export AR="${AR:-$HOMEBREW_PREFIX/bin/gcc-ar-15}"
            export RANLIB="${RANLIB:-$HOMEBREW_PREFIX/bin/gcc-ranlib-15}"
            export NM="${NM:-$HOMEBREW_PREFIX/bin/gcc-nm-15}"
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/gcc-15.cmake}"
        elif [ -x "$HOMEBREW_PREFIX/opt/llvm/bin/clang" ]; then
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/llvm-22.cmake}"
        fi
    else
        if [ -x "$HOMEBREW_PREFIX/opt/llvm/bin/clang" ]; then
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/llvm-22.cmake}"
        elif [ -x "$HOMEBREW_PREFIX/bin/gcc-15" ]; then
            export CC="${CC:-$HOMEBREW_PREFIX/bin/gcc-15}"
            export CXX="${CXX:-$HOMEBREW_PREFIX/bin/g++-15}"
            export AR="${AR:-$HOMEBREW_PREFIX/bin/gcc-ar-15}"
            export RANLIB="${RANLIB:-$HOMEBREW_PREFIX/bin/gcc-ranlib-15}"
            export NM="${NM:-$HOMEBREW_PREFIX/bin/gcc-nm-15}"
            export CMAKE_TOOLCHAIN_FILE="${CMAKE_TOOLCHAIN_FILE:-$_LOCAL_PLAT/cmake/toolchains/gcc-15.cmake}"
        fi
    fi
    unset _os
fi

### CUDA ###

# $_LOCAL_PLAT/.cuda is the per-PLAT symlink to the CUDA toolkit root.
# CUDA is not managed by bootstrap — create the symlink manually:
#   ln -sfn /usr/local/cuda "$_LOCAL_PLAT/.cuda"          # system toolkit
#   ln -sfn /opt/nvidia/cuda/12.6 "$_LOCAL_PLAT/.cuda"    # versioned install
# Different machines on a shared NFS home can point to different CUDA versions.
# CMake picks this up via CMAKE_CUDA_COMPILER in the active toolchain file.
if [ -e "$_LOCAL_PLAT/.cuda" ]; then
    _cuda_root="$(realpath "$_LOCAL_PLAT/.cuda" 2>/dev/null || true)"
    if [ -d "$_cuda_root" ]; then
        export CUDA_PATH="$_cuda_root"
        export CUDAToolkit_ROOT="$_cuda_root"
        case ":${PATH:-}:" in
            *":$_cuda_root/bin:"*) ;;
            *) export PATH="$_cuda_root/bin${PATH:+:$PATH}" ;;
        esac
    fi
    unset _cuda_root
fi

### COMPILER CACHING ###

if command -v ccache >/dev/null 2>&1; then
    export CMAKE_C_COMPILER_LAUNCHER=ccache
    export CMAKE_CXX_COMPILER_LAUNCHER=ccache
    export CMAKE_CUDA_COMPILER_LAUNCHER=ccache
    export CCACHE_DIR="${HOME}/.cache/ccache"  # lands on scratch when ~/.cache is symlinked
    # Size cache at 2% of total partition size, clamped to [10G, 100G].
    # df -Pk: POSIX portable, 1K blocks. total is column 2. result in GiB.
    _cache_total_kb="$(df -Pk "${HOME}/.cache" 2>/dev/null | awk 'NR==2{print $2}')"
    if [ -n "$_cache_total_kb" ]; then
        _cache_target_g=$(( _cache_total_kb / 50 / 1024 / 1024 ))
        [ "$_cache_target_g" -lt 10  ] && _cache_target_g=10
        [ "$_cache_target_g" -gt 100 ] && _cache_target_g=100
        export CCACHE_MAXSIZE="${_cache_target_g}G"
        unset _cache_total_kb _cache_target_g
    else
        export CCACHE_MAXSIZE=10G
    fi
fi
if command -v sccache >/dev/null 2>&1; then
    export RUSTC_WRAPPER=sccache
    export SCCACHE_DIR="${HOME}/.cache/sccache"  # lands on scratch when ~/.cache is symlinked
    # Size cache at 2% of total partition size, clamped to [10G, 100G].
    _cache_total_kb="$(df -Pk "${HOME}/.cache" 2>/dev/null | awk 'NR==2{print $2}')"
    if [ -n "$_cache_total_kb" ]; then
        _cache_target_g=$(( _cache_total_kb / 50 / 1024 / 1024 ))
        [ "$_cache_target_g" -lt 10  ] && _cache_target_g=10
        [ "$_cache_target_g" -gt 100 ] && _cache_target_g=100
        export SCCACHE_CACHE_SIZE="${_cache_target_g}G"
        unset _cache_total_kb _cache_target_g
    else
        export SCCACHE_CACHE_SIZE=10G
    fi
fi

### HOMEBREW ###

export HOMEBREW_NO_AUTO_UPDATE=1
export HOMEBREW_NO_INSTALL_FROM_API=1

### RUST ###

export RUST_BACKTRACE=1                      # show backtraces on panic (dev default)
export CARGO_NET_GIT_FETCH_WITH_CLI=true     # use git CLI for SSH key auth — critical on NFS homes

### PYTHON ###

export PYTHONDONTWRITEBYTECODE=1    # no .pyc files — saves NFS quota, avoids stale cache conflicts
export PYTHONFAULTHANDLER=1         # enable crash dumps — useful for debugging C extensions
if [ -e "$HOME/.pythonrc" ]; then
    export PYTHONSTARTUP="$HOME/.pythonrc"
fi
