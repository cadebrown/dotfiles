# Switch the active Nsight Systems default for this PLAT.
# Usage: nsys_switch public_nsys_2025.3.1.90
nsys_switch() {
    local _target="$_LOCAL_PLAT/.nsyss/$1"
    if [ ! -e "$_target" ]; then
        echo "ERROR: not found: $1" >&2
        echo "Run nsys_list to see available versions" >&2
        return 1
    fi
    ln -sfn "$_target" "$_LOCAL_PLAT/.nsys"
    nsys_use "$_LOCAL_PLAT/.nsys"
