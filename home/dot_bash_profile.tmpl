# .bash_profile - Bash login shell configuration
# For bash-specific interactive config, use ~/.bashrc
# This file mirrors the structure of ~/.zprofile for consistency

### PLATFORM ###

# _PLAT detection — identical logic to .zprofile.
# See .zprofile for detailed comments on PLAT format and NFS shared homes.
# Runs first so PATH is fully built before the zsh handoff below.
_plat_detect() {
    local _os _scan _dir _check
    _os="$(uname -s)"
    _scan="$HOME/dotfiles/install/plat"
    if [[ -d "$_scan" ]]; then
        for _dir in $(ls -1d "$_scan"/plat_"${_os}"_*/ 2>/dev/null | sort -r); do
            _check="$_dir/.plat_check.sh"
            if [[ -f "$_check" ]] && /bin/sh "$_check" 2>/dev/null; then
                printf '%s' "$(basename "$_dir")"
                # Source compile flags for this PLAT level
                [[ -f "$_dir/.plat_env.sh" ]] && source "$_dir/.plat_env.sh"
                return 0
            fi
        done
    fi
    echo "ERROR: no matching plat spec in ~/dotfiles/install/plat/" >&2
    printf '%s' "unknown"
}
export _PLAT="$(_plat_detect)"
# Resolve symlinks so all PATH entries use the same physical path.
# This prevents duplicate entries when ~/.local is a symlink to scratch space.
_local_root="$HOME/.local"
if [[ -L "$_local_root" ]]; then
    _local_root="$(readlink -f "$_local_root")"
fi
export _LOCAL_PLAT="$_local_root/$_PLAT"
unset _local_root
unset -f _plat_detect

### HOMEBREW (early — needed so zsh handoff finds the right zsh) ###

{{ if eq .chezmoi.os "darwin" -}}
if [ -e "$HOME/.homebrew" ]; then
    eval "$(~/.homebrew/bin/brew shellenv)"
elif [ -e "/opt/homebrew" ]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{ else -}}
if [ -x "$_LOCAL_PLAT/brew/bin/brew" ]; then
    eval "$($_LOCAL_PLAT/brew/bin/brew shellenv)"
fi
{{ end -}}

export PATH="$_LOCAL_PLAT/bin:$HOME/.local/bin:$PATH"

### ZSH HANDOFF ###
# Prefer zsh — exec into it for interactive login shells.
# Guards:
#   ZSH_VERSION set  → already in zsh, skip
#   stdin not a tty  → skip (SFTP, remote commands, scripts, scp)
#   zsh missing      → warn and stay in bash
#   zsh broken       → warn and stay in bash
if [[ -z "$ZSH_VERSION" ]]; then
    if [[ -t 0 ]]; then
        if _zsh="$(command -v zsh 2>/dev/null)"; then
            if "$_zsh" -c true 2>/dev/null; then
                export SHELL="$_zsh"
                exec "$_zsh" -l
            else
                echo "warning: zsh found at $_zsh but failed smoke test — staying in bash" >&2
            fi
        else
            echo "warning: zsh not found in PATH — staying in bash" >&2
        fi
        unset _zsh
    else
        [[ -n "$DF_DEBUG" ]] && echo "[dbug] bash->zsh handoff skipped: stdin is not a tty (tty=$(tty 2>/dev/null))" >&2
    fi
fi

### GENERAL ###

{{ if eq .chezmoi.os "darwin" -}}
export LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8
{{- else -}}
export LANG=en_US.UTF-8
# LC_ALL is intentionally not set on Linux — the locale archive can't be loaded
# by bash's setlocale(), causing "cannot change locale" warnings on every subshell.
# LANG alone is sufficient and doesn't trigger the warning.
{{- end }}

# Program defaults — see ~/.profile; PLAT-dependent config follows
. "$HOME/.profile"

### NODE (nvm) ###

export NVM_DIR="$_LOCAL_PLAT/nvm"
if [ -d "$NVM_DIR/versions/node" ]; then
    _nvm_default_bin="$NVM_DIR/versions/node/$(ls "$NVM_DIR/versions/node/" | sort -V | tail -1)/bin"
    [ -d "$_nvm_default_bin" ] && export PATH="$_nvm_default_bin:$PATH"
    unset _nvm_default_bin
fi

### RUST ###

export RUSTUP_HOME="$_LOCAL_PLAT/rustup"
export CARGO_HOME="$_LOCAL_PLAT/cargo"
export PATH="$CARGO_HOME/bin:$PATH"

### PYTHON (uv) ###

export UV_TOOL_BIN_DIR="$_LOCAL_PLAT/bin"
export UV_TOOL_DIR="$_LOCAL_PLAT/uv/tools"
export UV_PYTHON_INSTALL_DIR="$_LOCAL_PLAT/uv/python"

if [ -e "$_LOCAL_PLAT/venv/bin/activate" ]; then
    source "$_LOCAL_PLAT/venv/bin/activate"
fi

### PLATFORM-SPECIFIC ###
{{ if eq .chezmoi.os "darwin" -}}

if [ -S "$HOME/.colima/default/docker.sock" ]; then
    export DOCKER_HOST="unix://$HOME/.colima/default/docker.sock"
fi

{{ else -}}

export SSL_CERT_DIR=/usr/lib/ssl/certs

# LOCPATH tells brew's glibc where to find locale data (it has no locale archive
# by default). Without this, setlocale() falls back to C/ASCII and wcwidth()
# counts bytes instead of display columns, breaking ZLE completion rendering.
export LOCPATH="$_LOCAL_PLAT/locale"

### CUDA ###

cuda_use() {
    export CUDA_HOME="$1"
    if [ -e "$CUDA_HOME" ]; then
        export PATH="$CUDA_HOME/bin:$PATH"
        export LD_LIBRARY_PATH="$CUDA_HOME/lib64:$CUDA_HOME/lib:$LD_LIBRARY_PATH"
        export C_INCLUDE_PATH="$CUDA_HOME/include:$C_INCLUDE_PATH"
        export CPLUS_INCLUDE_PATH="$CUDA_HOME/include:$CPLUS_INCLUDE_PATH"
    else
        echo "ERROR: CUDA not found at $CUDA_HOME" >&2
    fi
}

if [ -e "$HOME/.cuda" ]; then cuda_use "$HOME/.cuda"; fi

if [ -e "$HOME/scratch" ]; then
    export SCRATCH=$(realpath "$HOME/scratch")
fi

if [ -d "$HOME/nsys" ]; then
    export PATH="$HOME/nsys/bin:$PATH"
    export LD_LIBRARY_PATH="$HOME/nsys/lib64:$HOME/nsys/lib:$LD_LIBRARY_PATH"
fi

if [ -d "$HOME/ncu" ]; then
    export PATH="$HOME/ncu/bin:$PATH"
    export LD_LIBRARY_PATH="$HOME/ncu/lib64:$HOME/ncu/lib:$LD_LIBRARY_PATH"
fi

docker() { /usr/bin/docker "$@"; }

{{ end -}}

### CREDENTIALS ###

# Private credential files (e.g. ~/.nvidia.env, ~/.work.env)
# Bash has no null glob — the [ -f ] guard handles the literal glob when no files match.
for f in "$HOME"/.*.env; do
    [ -f "$f" ] && . "$f"
done

### SSH AGENT ###

# Start ssh-agent only for local sessions — remote sessions rely on agent forwarding.
if [ -n "$SSH_CLIENT" ] || [ -n "$SSH_TTY" ]; then
    : # remote session — agent forwarding handles it
else
    if [ -z "$SSH_AUTH_SOCK" ]; then
        eval "$(ssh-agent -s)"
        for _k in "$HOME"/.ssh/id_*; do
            [ -f "$_k" ] || continue
            [[ "$_k" == *.pub ]] && continue
            ssh-add "$_k" 2>/dev/null || :
        done
        unset _k
    fi
fi

# Source bashrc if it exists (for interactive non-login shells)
if [ -f "$HOME/.bashrc" ]; then
    . "$HOME/.bashrc"
fi
