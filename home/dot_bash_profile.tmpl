# Auto-activate default nsys if nsys isn't already in PATH.
if ! command -v nsys >/dev/null 2>&1 && [ -e "$_LOCAL_PLAT/.nsys" ]; then
    nsys_use "$_LOCAL_PLAT/.nsys"
fi

