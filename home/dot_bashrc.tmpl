# .bashrc - interactive bash shell configuration
# Keep aliases in sync with .zshrc (home/dot_zshrc.tmpl)

### SHELL OPTIONS ###

shopt -s checkwinsize   # update LINES/COLUMNS after each command
shopt -s cdspell        # fix minor typos in cd targets
shopt -s dirspell 2>/dev/null || true  # bash 4+; macOS /bin/bash is 3.2       # fix typos during tab completion
shopt -s autocd 2>/dev/null || true  # bash 4+; macOS /bin/bash is 3.2         # bare path → cd into it
shopt -s cdable_vars    # cd $var expands $var as a directory path
shopt -s globstar 2>/dev/null || true  # bash 4+; macOS /bin/bash is 3.2       # ** recursive glob (like zsh)
shopt -s extglob        # extended patterns: ?(x) *(x) +(x) @(x) !(x)
shopt -s nocaseglob     # case-insensitive filename globbing
shopt -s histverify     # load !-expansions into edit buffer, don't execute
shopt -s cmdhist        # fold multi-line commands into one history entry
shopt -s lithist        # preserve newlines in multi-line history (needs cmdhist)

### HISTORY ###

# Unlimited history: -1 supported in bash 4.3+; fall back to a large number
if [[ ${BASH_VERSINFO[0]} -gt 4 || \
    ( ${BASH_VERSINFO[0]} -eq 4 && ${BASH_VERSINFO[1]} -ge 3 ) ]]; then
    HISTSIZE=-1
    HISTFILESIZE=-1
else
    HISTSIZE=500000
    HISTFILESIZE=1000000
fi

HISTTIMEFORMAT='%FT%T  '           # ISO 8601 timestamp prepended to every entry
HISTCONTROL=ignorespace:ignoredups  # skip space-prefixed cmds; skip consecutive dupes
                                    # NOTE: not erasedups — removing entries corrupts
                                    # concurrent sessions sharing the same HISTFILE
HISTIGNORE='ls:ll:la:cd:cd -:pwd:exit:clear:history:bg:fg'

shopt -s histappend  # append to HISTFILE on exit, never overwrite

# HISTFILE intentionally unset — bash defaults to ~/.bash_history, which lives
# at $HOME (precious, survives any ~/.local cleanup) and matches every tutorial.

### SIDECAR LOG ###

# Rich command log that captures what HISTFILE cannot: exit code, working directory,
# hostname, and shell PID. Format is TSV, one line per command:
#
#   iso_timestamp  host  shell_pid  exit_code  pwd  command
#
# Stored at ~/.bash_log. Search it with bash_log_search().
#
# Implementation notes:
#   - trap DEBUG fires in the CURRENT shell before each simple command (not a subshell),
#     so variable assignments persist back to the parent — this is why it works for
#     command capture while $() cannot.
#   - _BASH_IN_PROMPT suppresses re-capture while PROMPT_COMMAND runs its own commands.
#   - The trap is set last (after all rc setup) so sourcing .bashrc isn't logged.

_BASH_LOG="$HOME/.bash_log"
_BASH_LOGCMD=''
_BASH_IN_PROMPT=0

_bash_capture() {
    # Skip subshells and our own PROMPT_COMMAND bookkeeping
    [[ $BASH_SUBSHELL -gt 0 || $_BASH_IN_PROMPT -eq 1 ]] && return
    # Capture only the first simple command per prompt cycle (e.g. for pipelines,
    # we log the first segment; the full command is always in HISTFILE)
    [[ -n $_BASH_LOGCMD ]] && return
    # Via bash-preexec the command arrives as $1; raw DEBUG trap uses $BASH_COMMAND.
    _BASH_LOGCMD="${1:-$BASH_COMMAND}"
}

### PROMPT ###

# Color codes cached at startup — avoids spawning tput subprocesses per prompt.
# \001..\002 are readline's non-printing-sequence markers (same as \[..\] in PS1
# literals, but usable in dynamically-built strings).
if [[ -t 1 && $TERM != dumb && -n $TERM ]]; then
    _PC_BOLD=$'\001\e[1m\002'
    _PC_CYAN=$'\001\e[36m\002'
    _PC_RED=$'\001\e[31m\002'
    _PC_MAG=$'\001\e[35m\002'
    _PC_RST=$'\001\e[0m\002'
else
    _PC_BOLD='' _PC_CYAN='' _PC_RED='' _PC_MAG='' _PC_RST=''
fi

PROMPT_DIRTRIM=4  # truncate \w to last 4 path components with "..." prefix

_bash_prompt() {
    local _exit=$?
    _BASH_IN_PROMPT=1

    # Write sidecar log entry (2>/dev/null: silently skip if path unwritable)
    printf '%s\t%s\t%d\t%d\t%s\t%s\n' \
        "$(date -u +%FT%TZ 2>/dev/null)" \
        "${HOSTNAME%%.*}" "$$" "$_exit" "$PWD" "${_BASH_LOGCMD:--}" \
        >> "$_BASH_LOG" 2>/dev/null
    _BASH_LOGCMD=''

    # Flush new history to shared HISTFILE.
    # Append-only (no -c/-r reload) — safe for NFS: avoids read-after-write latency
    # and concurrent-write races. New sessions pick up all prior history on start.
    history -a

    # Git: branch name + staged/unstaged dirty marker
    # --untracked-files=no skips the untracked scan, which is slow on large/NFS repos
    local _git='' _branch
    if _branch=$(git symbolic-ref --short HEAD 2>/dev/null); then
        local _dirty=''
        [[ -n $(git status --porcelain --untracked-files=no 2>/dev/null) ]] \
            && _dirty=" ${_PC_RED}*${_PC_RST}"
        _git=" ${_PC_CYAN}${_branch}${_PC_RST}${_dirty}"
    fi

    # Prompt char: magenta on success, red on failure — pure theme aesthetic
    local _cc; [[ $_exit -eq 0 ]] && _cc=$_PC_MAG || _cc=$_PC_RED

    # Two-line prompt with blank line separator:
    #   ~/path/to/dir  main *
    #   $
    PS1="\n${_PC_BOLD}\w${_PC_RST}${_git}\n${_cc}\$${_PC_RST} "

    _BASH_IN_PROMPT=0
}

PROMPT_COMMAND='_bash_prompt'

### ALIASES ###

alias g='git'
alias p='python'
alias e='vim'
alias cat='bat --paging=never'

alias datestamp='date +"%Y%m%d"'
alias timestamp='date +"%Y%m%d%H%M%S"'
alias verify-path='bash ~/dotfiles/install/verify-path.sh'

# Codex profile shortcuts (default = unrestricted host access, no prompts)
alias codexs='codex -p deep'        # Sol, extra-high reasoning
alias codexr='codex -p review'      # Sol, read-only permissions

# codex launcher — MCP credentials resolved at launch (bearer_token_env_var /
# env_http_headers in config.toml; tokens never land on disk).
#   GH_TOKEN → GitHub MCP; GOOGLE_MCP_TOKEN + GOOGLE_CLOUD_PROJECT → Google's
#   official MCP servers (ADC access token, ~1h, + x-goog-user-project).
codex() {
    GH_TOKEN="${GH_TOKEN:-$(command gh auth token 2>/dev/null)}" \
    GOOGLE_MCP_TOKEN="${GOOGLE_MCP_TOKEN:-$(command gcloud auth application-default print-access-token 2>/dev/null)}" \
    GOOGLE_CLOUD_PROJECT="${GOOGLE_CLOUD_PROJECT:-$(command gcloud config get-value project 2>/dev/null)}" \
        command codex "$@"
}

# OpenCode consumes the same short-lived MCP credentials as Codex and starts
# in auto-approve mode. Explicit deny rules (the review agent) still apply.
opencode() {
    GH_TOKEN="${GH_TOKEN:-$(command gh auth token 2>/dev/null)}" \
    GOOGLE_MCP_TOKEN="${GOOGLE_MCP_TOKEN:-$(command gcloud auth application-default print-access-token 2>/dev/null)}" \
    GOOGLE_CLOUD_PROJECT="${GOOGLE_CLOUD_PROJECT:-$(command gcloud config get-value project 2>/dev/null)}" \
        command opencode --auto "$@"
}

# mlxserve — MLX OpenAI-compat server on :8080 (default Qwen3.6-27B 8bit)
mlxserve() {
    # Always --model-type lm — mlx-openai-server v1.8.1 VLM scheduler is broken
    local arg="${1:-qwen3.6-27b}" model parser=qwen3_coder rparser=qwen3_5
    case "$arg" in
        qwen3.6-27b)
            model="unsloth/Qwen3.6-27B-MLX-8bit" ;;
        qwen3.6-35b-a3b)
            model="mlx-community/Qwen3.6-35B-A3B-8bit"
            rparser=qwen3_moe ;;
        coder-next|qwen3-coder-next)
            model="mlx-community/Qwen3-Coder-Next-8bit"
            rparser="" ;;
        *)  model="$arg" ;;
    esac
    local port="${MLX_PORT:-8080}"
    echo "▸ MLX server: $model (served as qwen3.6-27b) on :$port"
    local args=(launch --model-type lm --model-path "$model"
        --served-model-name qwen3.6-27b
        --tool-call-parser "$parser" --enable-auto-tool-choice
        --kv-bits 8 --kv-group-size 64
        --host 127.0.0.1 --port "$port")
    [[ -n "$rparser" ]] && args+=(--reasoning-parser "$rparser")
    mlx-openai-server "${args[@]}"
}

{{ if eq .chezmoi.os "linux" -}}
alias open='xdg-open'
{{ end -}}

### FUNCTIONS ###

# mkcd — mkdir + cd in one
mkcd() { mkdir -p "$1" && cd "$1"; }

# up [N] — go up N directory levels (default 1)
up() {
    local p='' n=${1:-1}
    for (( i = 0; i < n; i++ )); do p="../$p"; done
    cd "$p"
}

# extract — universal archive unpacker
extract() {
    case "$1" in
        *.tar.bz2|*.tbz2)  tar xjf "$1"         ;;
        *.tar.gz|*.tgz)    tar xzf "$1"         ;;
        *.tar.xz)          tar xJf "$1"         ;;
        *.tar.zst)         tar --zstd -xf "$1"  ;;
        *.tar)             tar xf  "$1"         ;;
        *.bz2)             bunzip2 "$1"         ;;
        *.gz)              gunzip  "$1"         ;;
        *.zip)             unzip   "$1"         ;;
        *.7z)              7z x    "$1"         ;;
        *)  printf 'extract: unknown format: %s\n' "$1" >&2; return 1 ;;
    esac
}

# bash_log_search — search the sidecar command log
# Usage: bash_log_search <pattern> [grep options]
bash_log_search() {
    local log="$HOME/.bash_log"
    [[ -f $log ]] || { printf 'no log at %s\n' "$log" >&2; return 1; }
    grep --color=auto -i -- "$@" "$log"
}

### COMPLETIONS ###

# bash-completion@2 (Homebrew — provides completions for git, gh, cargo, etc.)
if [[ -n $HOMEBREW_PREFIX && -r $HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh ]]; then
    source "$HOMEBREW_PREFIX/etc/profile.d/bash_completion.sh"
fi

# Xan CSV tool
if command -v xan &>/dev/null; then
    _xan_complete() { xan compgen "$1" "$2" "$3"; }
    complete -F _xan_complete -o default xan
fi

# Direnv
if command -v direnv &>/dev/null; then
    eval "$(direnv hook bash)"
fi

# Zoxide
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init bash)"
fi

# fzf
if command -v fzf &>/dev/null; then
    eval "$(fzf --bash)"
fi

# bash-preexec owns the DEBUG trap when present (atuin needs it to record
# history in bash); _bash_capture rides preexec_functions instead of a raw
# trap. Fallback to the raw trap when bash-preexec is missing. Set last so
# .bashrc sourcing itself isn't logged as a user command.
if [[ -r "${HOMEBREW_PREFIX:-/opt/homebrew}/etc/profile.d/bash-preexec.sh" ]]; then
    . "${HOMEBREW_PREFIX:-/opt/homebrew}/etc/profile.d/bash-preexec.sh"
    preexec_functions+=(_bash_capture)
else
    trap '_bash_capture' DEBUG
fi

# atuin — history search on ctrl-r. MUST init after fzf (which also binds ^R)
# and after bash-preexec (recording hooks). Up-arrow stays native.
# Guard on init succeeding, not just the binary existing: a prebuilt atuin the
# loader rejects (needs newer glibc than the host) degrades quietly instead of
# erroring on every shell (install/rust.sh smoke-tests and rebuilds these).
if command -v atuin >/dev/null 2>&1 \
    && _atuin_init="$(atuin init bash --disable-up-arrow 2>/dev/null)"; then
    eval "$_atuin_init"
fi
unset _atuin_init
