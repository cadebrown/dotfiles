{{/*
LaunchAgent: keep mlx-openai-server running on localhost:8080.

This is what makes aider/opencode/pi "just work" when opened — without it,
each tool would fail to connect on first launch unless the user remembered
to run `mlxserve` first. Loaded by install/macos-services.sh.

Cost: ~25GB RAM permanently allocated for Qwen3-Coder-30B-A3B (4-bit MoE).
On a 128GB M3 Max that's 20%. To disable temporarily:
  launchctl bootout gui/$(id -u) ~/Library/LaunchAgents/dev.cade.mlxserve.plist
To re-enable:
  launchctl bootstrap gui/$(id -u) ~/Library/LaunchAgents/dev.cade.mlxserve.plist
*/ -}}
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTD/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>dev.cade.mlxserve</string>

    <key>ProgramArguments</key>
    <array>
        <string>{{ .chezmoi.homeDir }}/.local/bin/mlx-openai-server</string>
        <string>launch</string>
        <string>--model-type</string>
        <string>lm</string>
        <string>--model-path</string>
        <string>mlx-community/Qwen3-Coder-30B-A3B-Instruct-4bit</string>
        <string>--tool-call-parser</string>
        <string>qwen3_coder</string>
        <string>--enable-auto-tool-choice</string>
        <string>--host</string>
        <string>127.0.0.1</string>
        <string>--port</string>
        <string>8080</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>HF_HOME</key>
        <string>{{ .chezmoi.homeDir }}/.local/.cache/huggingface</string>
        <key>PATH</key>
        <string>{{ .chezmoi.homeDir }}/.local/bin:/opt/homebrew/bin:/usr/bin:/bin</string>
    </dict>

    <key>WorkingDirectory</key>
    <string>{{ .chezmoi.homeDir }}</string>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>30</integer>

    <key>StandardOutPath</key>
    <string>{{ .chezmoi.homeDir }}/.local/share/mlxserve/stdout.log</string>

    <key>StandardErrorPath</key>
    <string>{{ .chezmoi.homeDir }}/.local/share/mlxserve/stderr.log</string>

    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
