{{/*
pi (https://pi.dev) settings — global config at ~/.pi/agent/settings.json.

macOS: defaults to local MLX (Qwen3.6-27B 8-bit + q8 KV via mlxserve on :8080).
       MLX provider declared in models.json. Reasoning thinking enabled
       since 3.6 is reasoning-tuned (parser strips <think> blocks for output).
Linux: no MLX — defaults to anthropic/claude-haiku-4-5.

Anthropic + OpenAI are auto-detected from ANTHROPIC_API_KEY / OPENAI_API_KEY
env vars. /login is available for Claude Pro / ChatGPT Plus / Copilot
subscriptions if I want to swap from API-key billing.
*/ -}}
{
{{- if eq .chezmoi.os "darwin" }}
  "defaultProvider": "mlx",
  "defaultModel": "qwen3.6-27b",
  "defaultThinkingLevel": "medium",
{{- else }}
  "defaultProvider": "anthropic",
  "defaultModel": "{{ .models.haiku }}",
  "defaultThinkingLevel": "off",
{{- end }}
  "theme": "dotfiles",
  "hideThinkingBlock": false,
  "quietStartup": true,
  "collapseChangelog": true,
  "enableInstallTelemetry": false,
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 20000
  },
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000
  },
  "enabledModels": [
{{- if eq .chezmoi.os "darwin" }}
    "mlx/*",
{{- end }}
    "anthropic/{{ .models.sonnet }}*",
    "anthropic/{{ .models.opus }}*",
    "anthropic/{{ .models.haiku }}*",
    "openai/gpt-5*"
  ]
}
