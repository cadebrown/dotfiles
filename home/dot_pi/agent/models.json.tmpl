{{/*
pi custom-provider registry.

macOS-only: declares the local MLX provider serving Qwen3.6-27B 8-bit + q8 KV
cache via mlxserve on :8080. The model is exposed via served-model-name
"qwen3.6-27b" so this id stays stable even if you swap which physical model
mlxserve is loading.

Cloud providers (anthropic, openai) are built-in to pi — no block here.

Linux: empty providers map — pi uses built-in cloud providers only.

compat flags:
  - supportsDeveloperRole: false  — Qwen rejects OpenAI's "developer" role
  - supportsReasoningEffort: true — 3.6 IS reasoning-tuned; pi can pass
    reasoning effort hints. The mlx-openai-server reasoning_parser strips
    <think> blocks before the assistant message lands, so pi receives clean
    output and the user controls visibility via hideThinkingBlock.
*/ -}}
{
  "providers": {
{{- if eq .chezmoi.os "darwin" }}
    "mlx": {
      "name": "MLX (local)",
      "baseUrl": "http://localhost:8080/v1",
      "api": "openai-completions",
      "apiKey": "local",
      "compat": {
        "supportsDeveloperRole": false,
        "supportsReasoningEffort": true,
        "maxTokensField": "max_tokens"
      },
      "models": [
        {
          "id": "qwen3.6-27b",
          "name": "Qwen3.6-27B 8bit (MLX, q8 KV)",
          "reasoning": true,
          "input": ["text"],
          "contextWindow": 262144,
          "maxTokens": 32768,
          "cost": { "input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0 }
        }
      ]
    }
{{- end }}
  }
}
