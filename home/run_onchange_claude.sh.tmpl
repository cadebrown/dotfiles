#!/bin/bash
# Chezmoi re-runs this script whenever Claude plugin/MCP lists change.
# claude-plugins.txt hash: {{ include "../packages/claude-plugins.txt" | sha256sum }}
# mcp-servers.txt hash:    {{ include "../packages/mcp-servers.txt" | sha256sum }}
# overlay hashes:
{{- range glob (joinPath .chezmoi.workingTree "dotfiles-*/packages/mcp-servers.txt") }}
#   {{ . | include | sha256sum }} {{ . }}
{{- end }}
{{- range glob (joinPath .chezmoi.workingTree "dotfiles-*/packages/claude-plugins.txt") }}
#   {{ . | include | sha256sum }} {{ . }}
{{- end }}
{{- range glob (joinPath .chezmoi.workingTree "dotfiles-*/home/dot_claude/skills/*/SKILL.md") }}
#   {{ . | include | sha256sum }} {{ . }}
{{- end }}

set -euo pipefail
DOTFILES="$CHEZMOI_SOURCE_DIR/.."
bash "$DOTFILES/install/claude.sh"
