# ~/.aider.conf.yml — aider defaults
# Docs: https://aider.chat/docs/config/aider_conf.html
#
{{ if eq .chezmoi.os "darwin" -}}
# macOS: default to local Ollama inference.
# Context-boosted aliases are created by install/opencode.sh.
# Switch model at runtime: aider --model ollama/llama3.3:70b-ctx128k

model: ollama/qwen3-coder:30b-ctx256k
openai-api-base: http://127.0.0.1:11434/v1
openai-api-key: ollama
{{ else -}}
# Linux: no local Ollama — use ANTHROPIC_API_KEY or set --model at runtime.
# Example: aider --model anthropic/claude-sonnet-4-6

{{ end -}}
