# aider config — docs: https://aider.chat/docs/config/aider_conf.html
#
# macOS: defaults to local MLX (Qwen3-Coder-30B via mlxserve on :8080).
# Linux: no local default — set per-session with `--model <alias>` (cloud aliases
#        below; Linux has no MLX). Aider reads ANTHROPIC_API_KEY / OPENAI_API_KEY
#        from the env (sourced by ~/.zprofile from ~/.<service>.env).
#
# api_base for the local model lives in model-settings extra_params (NOT here)
# so cloud aliases keep routing to their real endpoints.
#
# Switch models per-session with `--model <alias>` or in-chat `/model <alias>`.

{{ if eq .chezmoi.os "darwin" -}}
model: openai/qwen3.6-27b
weak-model: openai/qwen3.6-27b     # commit msgs / summaries — keep local + free
editor-model: openai/qwen3.6-27b   # architect-mode editor — keep local + free
{{- else -}}
# No local default on Linux — pass --model at startup (e.g. --model sonnet).
# weak-model/editor-model intentionally unset; they'll inherit from --model.
{{- end }}

model-settings-file: ~/.aider.model.settings.yml
model-metadata-file: ~/.aider.model.metadata.json

# `alias:` is singular (aider quirk). Format: short:full-litellm-id.
alias:
{{- if eq .chezmoi.os "darwin" }}
  - "mlx:openai/qwen3.6-27b"
  - "qwen:openai/qwen3.6-27b"
  - "q:openai/qwen3.6-27b"
{{- end }}
  - "sonnet:anthropic/claude-sonnet-4-6"
  - "opus:anthropic/claude-opus-4-7"
  - "haiku:anthropic/claude-haiku-4-5"
  - "gpt5:openai/gpt-5"

# Auto-load coding conventions every session (read-only context).
read:
  - ~/.config/aider/CONVENTIONS.md

# I drive commits manually — let aider stage but never commit/push on its own.
auto-commits: false
dirty-commits: false
gitignore: true

# UX — colors mirror the dotfiles palette (matches Claude statusline + pi theme):
#   #5fafd7 steel  primary   #5fffff sky    accent  #af5fff purple   thinking
#   #d787af pink   warning   #87d787 green  success #ff5f5f red      error
dark-mode: true
stream: true
pretty: true
cache-prompts: true       # Anthropic prompt cache; harmless for non-cache providers
show-model-warnings: true
code-theme: monokai       # syntax highlighting in code blocks
user-input-color:                 "#5fffff"
assistant-output-color:           "#5fafd7"
tool-output-color:                "#9e9e9e"
tool-error-color:                 "#ff5f5f"
tool-warning-color:               "#d787af"
completion-menu-color:            "#5fafd7"
completion-menu-bg-color:         "#1a1a1a"
completion-menu-current-color:    "#1a1a1a"
completion-menu-current-bg-color: "#5fafd7"

# Hygiene
analytics-disable: true
check-update: false       # chezmoi/bootstrap.sh owns updates
