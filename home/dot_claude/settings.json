{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "900000",
    "MAX_MCP_OUTPUT_TOKENS": "10000",
    "BASH_MAX_OUTPUT_LENGTH": "20000"
  },
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "mcp__cloudflare__*",
      "mcp__github__push_files",
      "mcp__github__create_or_update_file",
      "mcp__github__delete_file",
      "mcp__github__merge_pull_request",
      "mcp__github__create_repository"
    ]
  },
  "cleanupPeriodDays": 3650,
  "model": "opus[1m]",
  "fallbackModel": [
    "sonnet[1m]"
  ],
  "sandbox": {
    "enabled": false,
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "$HOME/.cache",
        "$HOME/.config",
        "$HOME/.local",
        "$HOME/.npm",
        "$HOME/.claude",
        "$HOME/.codex",
        "$HOME/.cursor",
        "$HOME/.agents",
        "$HOME/.ollama",
        "$HOME/kb",
        "$HOME/.homebrew",
        "$HOME/Library/Application Support",
        "$HOME/Library/Caches",
        "$HOME/Library/Preferences"
      ]
    }
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"terminalSequence\":\"\\u001b]9;Claude needs attention\\u0007\"}'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/chezmoi-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "debug-skill-marketplace": {
      "source": {
        "source": "github",
        "repo": "AlmogBaku/debug-skill"
      }
    }
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "c-review@trailofbits": true,
    "codex@openai-codex": true,
    "plugin-dev@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "testing-handbook-skills@trailofbits": true,
    "debugging-code@debug-skill-marketplace": true
  },
  "outputStyle": "cade",
  "skipDangerousModePermissionPrompt": true
}
