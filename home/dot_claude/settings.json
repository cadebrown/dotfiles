{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_PROMPT_CACHING_1H": "1",
    "BASH_DEFAULT_TIMEOUT_MS": "300000",
    "BASH_MAX_TIMEOUT_MS": "900000",
    "MAX_MCP_OUTPUT_TOKENS": "10000",
    "BASH_MAX_OUTPUT_LENGTH": "20000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_MAX_SUBAGENTS_PER_SESSION": "50",
    "CLAUDE_CODE_MAX_WEB_SEARCHES_PER_SESSION": "75"
  },
  "teammateMode": "auto",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "skipDangerousModePermissionPrompt": true,
  "cleanupPeriodDays": 3650,
  "model": "claude-fable-5[1m]",
  "fallbackModel": [
    "claude-sonnet-5[1m]"
  ],
  "effortLevel": "xhigh",
  "sandbox": {
    "enabled": false
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "printf '%s' '{\"terminalSequence\":\"\\u001b]9;Claude needs attention\\u0007\"}'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/chezmoi-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/rtk-rewrite.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "extraKnownMarketplaces": {
    "trailofbits": {
      "source": {
        "source": "github",
        "repo": "trailofbits/skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "debug-skill-marketplace": {
      "source": {
        "source": "github",
        "repo": "AlmogBaku/debug-skill"
      }
    },
    "lean4-skills": {
      "source": {
        "source": "github",
        "repo": "cameronfreer/lean4-skills"
      }
    }
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "c-review@trailofbits": true,
    "rust-review@trailofbits": true,
    "static-analysis@trailofbits": true,
    "dimensional-analysis@trailofbits": true,
    "mutation-testing@trailofbits": true,
    "math-olympiad@claude-plugins-official": true,
    "codex@openai-codex": true,
    "plugin-dev@claude-plugins-official": true,
    "mcp-server-dev@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "testing-handbook-skills@trailofbits": true,
    "debugging-code@debug-skill-marketplace": true,
    "lean4@lean4-skills": true
  },
  "outputStyle": "cade"
}
