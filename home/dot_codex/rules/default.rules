prefix_rule(pattern=["cargo", "add"], decision="allow")
prefix_rule(pattern=["cargo", "check"], decision="allow")
prefix_rule(pattern=["cargo", "test"], decision="allow")
prefix_rule(pattern=["cargo", "build"], decision="allow")
prefix_rule(pattern=["dx", "serve"], decision="allow")
prefix_rule(pattern=["dx", "build"], decision="allow")
prefix_rule(pattern=["npx", "playwright", "install"], decision="allow")
prefix_rule(pattern=["npm", "run", "e2e"], decision="allow")
prefix_rule(pattern=["npm", "run", "tutorial:video"], decision="allow")
prefix_rule(pattern=["npm", "run", "tutorial:compose"], decision="allow")
prefix_rule(pattern=["make", "test-web"], decision="allow")
prefix_rule(pattern=["set", "-a"], decision="allow")
prefix_rule(pattern=["source", ".env"], decision="allow")
prefix_rule(pattern=["curl", "-L", "--fail"], decision="allow")
