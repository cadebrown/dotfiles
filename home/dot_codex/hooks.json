{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/df-chezmoi-guard",
            "statusMessage": "Checking chezmoi-managed paths"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.codex/rtk-rewrite.sh",
            "timeout": 10,
            "statusMessage": "rtk rewrite"
          }
        ]
      }
    ]
  }
}
