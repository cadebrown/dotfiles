{
  "mcpServers": {
    "bare": {
      "command": "solobinary"
    },
    "c7srv": {
      "headers": {
        "CONTEXT7_API_KEY": "fixture-fixture-c7"
      },
      "url": "https://c7.example/mcp"
    },
    "exasrv": {
      "headers": {
        "x-api-key": "fixture-fixture-exa"
      },
      "url": "https://exa.example/mcp"
    },
    "ghsrv": {
      "headers": {
        "Authorization": "Bearer fixture-fixture-github"
      },
      "url": "https://gh.example/mcp"
    },
    "hfsrv": {
      "headers": {
        "Authorization": "Bearer fixture-fixture-hf"
      },
      "url": "https://hf.example/mcp"
    },
    "mystery": {
      "url": "https://mystery.example/mcp"
    },
    "oauthsrv": {
      "url": "https://oauth.example/mcp"
    },
    "plainsrv": {
      "url": "https://plain.example/mcp"
    },
    "tavsrv": {
      "headers": {
        "Authorization": "Bearer fixture-fixture-tav"
      },
      "url": "https://tav.example/mcp"
    },
    "tool": {
      "args": [
        "some-tool",
        "--flag",
        "val"
      ],
      "command": "uvx"
    },
    "urlkey": {
      "url": "https://key.example/fixture-fixture-url/v2/mcp"
    }
  }
}
